{
  "name": "secure-hub-frontend",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "start:dev": "ng serve --configuration=development",
    "start:pre": "ng serve --configuration=pre",
    "build": "npm run lint && ng build",
    "build:dev": "npm run lint && ng build --configuration=development",
    "build:pre": "npm run lint && ng build --configuration=pre",
    "build:prod": "npm run lint && ng build --configuration=production",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@primeng/themes": "^21.0.4",
    "@primeuix/themes": "^2.0.3",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "ngx-webcam": "^0.4.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
